// YARA String Pattern Flow
digraph {
	bgcolor=white fontname=Arial fontsize=12 rankdir=TB
	node [fontname=Arial fontsize=10]
	edge [fontname=Arial fontsize=9]
	subgraph cluster_plain {
		color=blue fillcolor=lightblue label="Plain String Patterns" style=filled
		node [fillcolor=lightcyan shape=box style="rounded,filled"]
		pattern_1 [label="$a\n\"hello\"\nLength: 5"]
	}
	subgraph cluster_hex {
		color=orange fillcolor=lightyellow label="Hex Patterns" style=filled
		node [fillcolor=yellow shape=hexagon style=filled]
		pattern_2 [label="$b\nTokens: 5\nWildcards: 0 (0.0%)"]
	}
	subgraph cluster_regex {
		color=green fillcolor=lightgreen label="Regex Patterns" style=filled
		node [fillcolor=lightgreen shape=ellipse style=filled]
		pattern_3 [label="$c\n/te(s|x)t/\nGroups: 1"]
	}
	rule_metrics_rule [label="Rule: metrics_rule" fillcolor=lightgray shape=diamond style=filled]
	rule_metrics_rule -> pattern_1 [color=gray style=dotted]
	rule_metrics_rule -> pattern_2 [color=gray style=dotted]
	rule_metrics_rule -> pattern_3 [color=gray style=dotted]
}
