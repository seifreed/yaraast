{
  "name": "yaraast",
  "displayName": "YARAAST - YARA Language Support",
  "description": "Language support for YARA rules with AST-powered features",
  "version": "0.1.0",
  "publisher": "seifreed",
  "icon": "icons/yaraast.png",
  "author": {
    "name": "Marc Rivero",
    "email": "mriverolopez@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/seifreed/yaraast"
  },
  "homepage": "https://github.com/seifreed/yaraast/tree/main/vscode-yaraast",
  "bugs": {
    "url": "https://github.com/seifreed/yaraast/issues"
  },
  "license": "MIT",
  "galleryBanner": {
    "color": "#1f3a5f",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Formatters",
    "Other"
  ],
  "keywords": [
    "yara",
    "yara-rules",
    "malware",
    "security",
    "threat-hunting"
  ],
  "activationEvents": [
    "onLanguage:yara"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "yara",
        "aliases": [
          "YARA",
          "yara"
        ],
        "extensions": [
          ".yar",
          ".yara"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/yara-light.png",
          "dark": "./icons/yara-dark.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "yara",
        "scopeName": "source.yara",
        "path": "./syntaxes/yara.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "YARAAST",
      "properties": {
        "yaraast.lsp.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable/disable the YARAAST language server"
        },
        "yaraast.lsp.pythonPath": {
          "type": "string",
          "default": "python",
          "description": "Path to Python interpreter (must have yaraast[lsp] installed)"
        },
        "yaraast.lsp.serverModule": {
          "type": "string",
          "default": "yaraast",
          "description": "Python module used to start the YARAAST language server"
        },
        "yaraast.lsp.dialectMode": {
          "type": "string",
          "enum": [
            "auto",
            "yara",
            "yaral",
            "yarax"
          ],
          "default": "auto",
          "description": "Force a dialect mode for the language server or let it auto-detect"
        },
        "yaraast.lsp.cacheWorkspace": {
          "type": "boolean",
          "default": true,
          "description": "Keep a cached workspace index for cross-file navigation"
        },
        "yaraast.lsp.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Traces the communication between VS Code and the language server"
        },
        "yaraast.formatting.style": {
          "type": "string",
          "enum": [
            "default",
            "compact",
            "readable",
            "verbose"
          ],
          "default": "default",
          "description": "Code formatting style"
        },
        "yaraast.formatting.indentSize": {
          "type": "number",
          "default": 4,
          "minimum": 1,
          "description": "Indent size passed to the language server formatter"
        },
        "yaraast.formatting.braceStyle": {
          "type": "string",
          "enum": [
            "same_line",
            "new_line",
            "k_and_r"
          ],
          "default": "same_line",
          "description": "Brace placement style passed to the language server formatter"
        },
        "yaraast.formatting.sortMeta": {
          "type": "boolean",
          "default": false,
          "description": "Sort meta entries during formatting"
        },
        "yaraast.formatting.sortStrings": {
          "type": "boolean",
          "default": false,
          "description": "Sort strings during formatting"
        },
        "yaraast.diagnostics.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable/disable diagnostics"
        }
      }
    },
    "configurationDefaults": {
      "[yara]": {
        "editor.tabSize": 4,
        "editor.insertSpaces": true,
        "editor.formatOnSave": true
      }
    },
    "snippets": [
      {
        "language": "yara",
        "path": "./snippets/yara.code-snippets"
      }
    ],
    "commands": [
      {
        "command": "yaraast.restartServer",
        "title": "YARAAST: Restart Language Server"
      },
      {
        "command": "yaraast.showOutputChannel",
        "title": "YARAAST: Show Output Channel"
      },
      {
        "command": "yaraast.showServerInfo",
        "title": "YARAAST: Show Server Configuration"
      },
      {
        "command": "yaraast.selectDialectMode",
        "title": "YARAAST: Select Dialect Mode"
      },
      {
        "command": "yaraast.toggleServer",
        "title": "YARAAST: Toggle Language Server"
      },
      {
        "command": "yaraast.showServerStatus",
        "title": "YARAAST: Show Server Status"
      },
      {
        "command": "yaraast.copyServerStatus",
        "title": "YARAAST: Copy Server Status"
      },
      {
        "command": "yaraast.showRuntimeMetrics",
        "title": "YARAAST: Show Runtime Metrics"
      },
      {
        "command": "yaraast.openRuntimeDashboard",
        "title": "YARAAST: Open Runtime Dashboard"
      },
      {
        "command": "yaraast.previewRefactors",
        "title": "YARAAST: Preview Refactors"
      },
      {
        "command": "yaraast.diagnoseServer",
        "title": "YARAAST: Diagnose Server Environment"
      },
      {
        "command": "yaraast.openSettings",
        "title": "YARAAST: Open Extension Settings"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "package": "vsce package",
    "verify:vsix": "python3 scripts/verify_vsix.py"
  },
  "devDependencies": {
    "@types/node": "^18.x",
    "@types/vscode": "^1.75.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "typescript": "^5.0.0",
    "@vscode/vsce": "^2.19.0"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}
