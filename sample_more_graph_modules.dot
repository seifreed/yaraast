// YARA Module Dependencies
digraph {
	bgcolor=white fontname=Arial rankdir=TB
	node [fillcolor=lightcyan shape=box style="rounded,filled"]
	mod_pe [label="Module: pe" fillcolor=lightcyan]
	node [fillcolor=lightblue shape=ellipse]
	dep_target [label=dep_target]
	sample_more [label=sample_more]
	mod_pe -> sample_more [label="imported by"]
}
